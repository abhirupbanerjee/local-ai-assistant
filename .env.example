# Policy Bot - Environment Configuration
# Copy this file to .env.local for development or .env for production
#
# Legend:
#   [REQUIRED] - Must be set for the application to work
#   [OPTIONAL] - Enhanced features, can be omitted
#   [PRODUCTION] - Required only for production deployment
#   [HAS DEFAULT] - Has a sensible default, override if needed

# ============================================================================
#                           REQUIRED - Core Configuration
# ============================================================================

# [REQUIRED] OpenAI API Key
# - Direct to OpenAI: Your actual OpenAI API key (sk-...)
# - Via LiteLLM proxy: Set to your LITELLM_MASTER_KEY value
OPENAI_API_KEY=sk-your-api-key-here

# [REQUIRED] Admin email addresses (comma-separated)
# These users will have full admin access to the dashboard
ADMIN_EMAILS=admin@example.com

# [REQUIRED for Production] NextAuth secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-secure-random-string

# ============================================================================
#                         REQUIRED - Infrastructure Services
# ============================================================================
#
# DOCKER COMPOSE PROFILES:
# Use profiles to start only the services you need:
#   PostgreSQL + Qdrant:   docker compose --profile postgres --profile qdrant up -d

# [OPTIONAL] Qdrant Connection
# Development: localhost | Production: qdrant (Docker service name)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ============================================================================
#                         Database Provider Selection
# ============================================================================

# [HAS DEFAULT] Database Provider Selection
# Options: sqlite | postgres
# Default: sqlite (use --profile postgres for PostgreSQL)
DATABASE_PROVIDER=sqlite

# [REQUIRED when DATABASE_PROVIDER=sqlite] SQLite database path
# Development: ./data/policybot.db | Production: /app/data/policybot.db
SQLITE_DB_PATH=./data/policybot.db

# [REQUIRED when DATABASE_PROVIDER=postgres] PostgreSQL connection settings
# Set these when using DATABASE_PROVIDER=postgres
POSTGRES_USER=policybot
POSTGRES_PASSWORD=
POSTGRES_DB=policybot
# Full connection URL (auto-composed in Docker, set manually for local dev)
DATABASE_URL=postgresql://policybot:password@localhost:5432/policybot

# [HAS DEFAULT] PostgreSQL Connection Pool Settings (only used with DATABASE_PROVIDER=postgres)
# Adjust based on concurrent users. See docs/tech/DB-techstack.md for sizing guide.
# Default: 20 (suitable for ~100 concurrent users with typical query patterns)
DATABASE_POOL_MAX=20
# Idle timeout in ms - connections idle longer than this are closed (default: 30000)
DATABASE_POOL_IDLE_TIMEOUT=30000
# Connection timeout in ms - max time to wait for a connection (default: 10000)
DATABASE_POOL_CONNECTION_TIMEOUT=10000

# [REQUIRED] Redis Connection
# Development: redis://localhost:6379 | Production: redis://redis:6379
REDIS_URL=redis://localhost:6379

# [REQUIRED] Data storage directory
# Development: ./data | Production: /app/data
DATA_DIR=./data

# [HAS DEFAULT] Maximum upload size for file uploads (backup restore, documents)
# Accepts values like: 100mb, 500mb, 1gb, 2gb
# Default: 500mb (requires rebuild to take effect)
# Increase if you have large backup files to restore
MAX_UPLOAD_SIZE=500mb

# ============================================================================
#                      REQUIRED for Production - Authentication
# ============================================================================

# [PRODUCTION] Base URL of your application
# When deploying behind a reverse proxy (like Traefik), NextAuth automatically trusts
# X-Forwarded-* headers when trustHost: true is set in auth-options.ts
# Ensure NEXTAUTH_URL matches your external HTTPS domain (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# [PRODUCTION] At least one OAuth provider must be configured:

# Azure AD Configuration (get from Azure Portal > App registrations)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Google OAuth Configuration (get from Google Cloud Console > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [HAS DEFAULT] Access control mode
# - 'allowlist': Only users in the database can sign in (default)
# - 'domain': Any user from ALLOWED_DOMAINS can sign in
ACCESS_MODE=allowlist

# [OPTIONAL] Comma-separated list of allowed email domains
# Only used when ACCESS_MODE=domain
ALLOWED_DOMAINS=example.com,company.org

# [DEVELOPMENT ONLY] Set to 'true' to disable auth entirely
AUTH_DISABLED=true

# [OPTIONAL] Credentials Authentication
# Enable email/password login (default: enabled)
# Useful for: fresh VM setup, development mode, offline/Ollama scenarios
# Set password for the first admin in ADMIN_EMAILS list
# Only used on first run if admin has no password set
CREDENTIALS_ADMIN_PASSWORD=

# ============================================================================
#                      REQUIRED for Production - Deployment
# ============================================================================

# [OPTIONAL] Allowed origins for iframe embedding on /e/* embed routes
# Comma-separated list of origins that may embed the chatbot widget
# Example: https://portal.example.com,https://other.example.com
ALLOWED_EMBED_ORIGINS=

# [PRODUCTION] Your domain name for Traefik routing
DOMAIN=policybot.example.com

# [PRODUCTION] Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# ============================================================================
#                         OPTIONAL - LiteLLM Proxy
# ============================================================================
# Use LiteLLM for multi-provider LLM support (OpenAI, Mistral, Ollama, Azure)
# If not using LiteLLM, leave OPENAI_BASE_URL empty to connect directly to OpenAI

# [OPTIONAL] Point to LiteLLM proxy for multi-provider support
# Leave empty/omit to connect directly to OpenAI
OPENAI_BASE_URL=http://localhost:4000/v1

# [OPTIONAL] LiteLLM authentication keys
# Generate with: openssl rand -hex 16
LITELLM_MASTER_KEY=sk-litellm-master-change-this
LITELLM_SALT_KEY=sk-litellm-salt-change-this

# [OPTIONAL] Direct URL to LiteLLM management API (bypasses reverse proxy)
# Set this if OPENAI_BASE_URL routes through nginx/a proxy that blocks the /model/new admin endpoint.
# Example (Docker): LITELLM_ADMIN_URL=http://litellm:4000
# LITELLM_ADMIN_URL=

# [OPTIONAL] PostgreSQL database for LiteLLM (virtual keys, spend tracking)
# Use host.docker.internal instead of localhost when running in Docker
LITELLM_DATABASE_URL=postgresql://postgres:password@host.docker.internal:5432/litellm

# ============================================================================
#                      OPTIONAL - Additional LLM Providers
# ============================================================================
# These are used by LiteLLM proxy for multi-provider support

# [OPTIONAL] Mistral API - Used for chat completions and PDF OCR
# Get from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# [OPTIONAL] Google Gemini - Advanced reasoning models with 1M context
# Get from: https://ai.google.dev/
GEMINI_API_KEY=

# [OPTIONAL] Ollama - Local models (no API cost)
# Use http://host.docker.internal:11434 when running in Docker
OLLAMA_API_BASE=http://localhost:11434

# [OPTIONAL] Anthropic Claude - Advanced reasoning and coding models
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# [OPTIONAL] DeepSeek - Cost-effective reasoning models
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# [OPTIONAL] Fireworks AI - SOC2/GDPR/HIPAA compliant, Zero Data Retention
# Hosts: MiniMax M2.5, Kimi K2.5, GPT-OSS 20B/120B, Qwen3 8B
# Get from: https://fireworks.ai/account/api-keys
FIREWORKS_AI_API_KEY=

# ============================================================================
#                      OPTIONAL - Document Processing
# ============================================================================

# [OPTIONAL] Azure Document Intelligence - Enhanced Office document support
# Supports: PDF, DOCX, XLSX, PPTX, Images with better quality than basic extraction
# Get from Azure Portal > Cognitive Services > Document Intelligence
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=

# ============================================================================
#                      OPTIONAL - RAG Enhancements
# ============================================================================

# [OPTIONAL] Cohere API - Chunk reranking for improved search relevance
# Improves RAG quality by re-scoring retrieved chunks
# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# [OPTIONAL] Tavily API - Web search and URL extraction
# Enables real-time web search and web page content extraction
# Get from: https://tavily.com
TAVILY_API_KEY=

# [OPTIONAL] Website Analysis (Google PageSpeed Insights)
# Enables website performance, accessibility, SEO, and best practices analysis
# Works without API key but recommended for higher rate limits
# Get from: https://console.cloud.google.com/apis/credentials
# Note: Falls back to GOOGLE_API_KEY if PAGESPEED_API_KEY is not set
PAGESPEED_API_KEY=

# [OPTIONAL] Code Analysis (SonarCloud)
# Enables code quality analysis: bugs, vulnerabilities, code smells, coverage
# Required for code_analysis tool to function
# Get from: https://sonarcloud.io/account/security
SONARCLOUD_TOKEN=
SONARCLOUD_ORGANIZATION=

# [OPTIONAL] Load Testing (k6 Cloud)
# Enables distributed load testing for website performance validation
# Free tier: 50 VUh/month (~12 tests at 50 users for 5 min)
# Get from: https://app.k6.io/account/api-token
# NOTE: Can also be configured via Admin UI > Tools > Load Testing
K6_CLOUD_API_TOKEN=

# [OPTIONAL] YouTube transcript extraction
# NOTE: YouTube API key is now configured via Admin > Tools > YouTube
# Get API key from: https://supadata.ai (free $5 credit = ~5000 transcripts)
# The youtube-transcript npm fallback is available but may be blocked by YouTube

# ============================================================================
#                      OPTIONAL - Data Source Encryption
# ============================================================================

# [RECOMMENDED] Encryption key for API credentials stored in database
# Generate with: openssl rand -hex 32
# Required for secure storage of API keys and tokens for external data sources
DATA_SOURCE_ENCRYPTION_KEY=

# [HAS DEFAULT] Embedding model name
# Must match LiteLLM config or OpenAI model
# Default: text-embedding-3-large (3072 dimensions)
EMBEDDING_MODEL=text-embedding-3-large
