# =============================================================================
# Local AI Assistant - Environment Configuration Template
# =============================================================================
#
# USAGE:
#   1. Copy this file to .env.local for local development
#   2. Copy to .env for production deployment
#   3. Adjust values as needed for your environment
#
# LEGEND:
#   [REQUIRED]    - Must be set for the application to work
#   [OPTIONAL]    - Enhanced features, can be omitted
#   [PRODUCTION]  - Required only for production deployment
#   [HAS DEFAULT] - Has a sensible default, override if needed
#
# =============================================================================

# =============================================================================
# SECTION 1: Core Configuration
# =============================================================================

# [REQUIRED] Admin email addresses (comma-separated)
# These users will have full admin access to the dashboard
ADMIN_EMAILS=admin@example.com

# [REQUIRED for Production] NextAuth secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# [PRODUCTION] Base URL of your application
# For production, set to your actual domain (e.g., https://your-domain.com)
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# SECTION 2: LLM Configuration (Ollama)
# =============================================================================

# [HAS DEFAULT] Ollama mode: "docker" or "system"
# - docker: Ollama runs in Docker container (default)
# - system: Ollama runs as native system service
OLLAMA_MODE=docker

# [REQUIRED] Ollama API Base URL
# Auto-configured based on OLLAMA_MODE if not set
# Local Development: http://localhost:11434
# Docker Production: http://ollama:11434
# Azure Container Apps: http://<ollama-internal-ip>:11434
# Override explicitly if needed:
OLLAMA_API_BASE=http://localhost:11434

# For system mode, you can set a separate URL:
# OLLAMA_SYSTEM_API_BASE=http://localhost:11434

# [OPTIONAL] Ollama Cloud API Key
# Enables running models on Ollama's cloud infrastructure
# Get your API key at: https://ollama.com/account
# Cloud models are identified by -cloud suffix (e.g., llama3.3:70b-cloud)
OLLAMA_API_KEY=

# [HAS DEFAULT] Default Ollama model to use
# Options: qwen3:1.7b, qwen3.5:0.8b, gemma4:e2b, gemma3:latest, llama3.2:3b, mistral:7b
# Default: qwen3:1.7b
DEFAULT_OLLAMA_MODEL=qwen3:1.7b

# [HAS DEFAULT] Ollama model preloading
# OLLAMA_MODEL is warmed up on container start. OLLAMA_PULL_MODELS are downloaded
# into the persistent Ollama volume for chat (LLMs only - embeddings/reranking use local models).
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_PULL_MODELS=qwen3:1.7b,qwen3.5:0.8b

# [HAS DEFAULT] Ollama runtime settings
# How long to keep model loaded (default: 5 minutes)
OLLAMA_KEEP_ALIVE=5m
# Maximum concurrent requests (default: 1)
OLLAMA_NUM_PARALLEL=2
# Context length (default: 8192)
OLLAMA_CONTEXT_LENGTH=8192

# =============================================================================
# SECTION 3: Database Configuration
# =============================================================================

# [HAS DEFAULT] Database Provider
# Options: sqlite | postgres
# Default for Docker/local VM setup: postgres
DATABASE_PROVIDER=postgres

# [REQUIRED when DATABASE_PROVIDER=sqlite] SQLite database path
SQLITE_DB_PATH=./data/local-ai-assistant.db

# [REQUIRED when DATABASE_PROVIDER=postgres] PostgreSQL connection
POSTGRES_USER=laap
POSTGRES_PASSWORD=laap-local-password
POSTGRES_DB=laap
# Full connection URL (auto-composed in Docker)
DATABASE_URL=postgresql://laap:laap-local-password@localhost:5432/laap

# [HAS DEFAULT] PostgreSQL Connection Pool (only for postgres)
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_POOL_CONNECTION_TIMEOUT=10000

# =============================================================================
# SECTION 4: Vector Store (Qdrant)
# =============================================================================

# [HAS DEFAULT] Qdrant host
# Local Development: localhost
# Docker Production: qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# =============================================================================
# SECTION 5: Redis Cache
# =============================================================================

# [REQUIRED] Redis connection URL
# Local Development: redis://localhost:6379
# Docker Production: redis://redis:6379
REDIS_URL=redis://localhost:6379

# =============================================================================
# SECTION 6: Storage & Uploads
# =============================================================================

# [REQUIRED] Data storage directory
# Local Development: ./data
# Docker Production: /app/data
DATA_DIR=./data

# [HAS DEFAULT] Maximum upload size
# Default: 500mb (requires rebuild to take effect)
MAX_UPLOAD_SIZE=500mb

# =============================================================================
# SECTION 7: Authentication
# =============================================================================

# [DEVELOPMENT ONLY] Set to 'true' to disable auth entirely
AUTH_DISABLED=true

# Option 1: Email/Password Authentication
# Set CREDENTIALS_ADMIN_PASSWORD to enable
CREDENTIALS_ADMIN_PASSWORD=

# Option 2: Azure AD OAuth
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Option 3: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [HAS DEFAULT] Access control mode
# - 'allowlist': Only users in the database can sign in
# - 'domain': Any user from ALLOWED_DOMAINS can sign in
ACCESS_MODE=allowlist

# [OPTIONAL] Allowed email domains (only when ACCESS_MODE=domain)
ALLOWED_DOMAINS=example.com

# =============================================================================
# SECTION 8: Production Deployment
# =============================================================================

# [PRODUCTION] Your domain name for Traefik routing
DOMAIN=local-ai-assistant.example.com

# [PRODUCTION] Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# [OPTIONAL] Allowed origins for iframe embedding on /e/* routes
ALLOWED_EMBED_ORIGINS=

# =============================================================================
# SECTION 9: Optional - Embeddings & Reranking
# =============================================================================

# [HAS DEFAULT] Embedding model
# In-process local (recommended): bge-m3 (1024 dim, multilingual) or mxbai-embed-large (1024 dim)
# Ollama: ollama-qwen3-embedding:0.6b (1024 dim), ollama-mxbai-embed-large (1024 dim)
# Cloud: text-embedding-3-large (3072 dim)
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024

# [OPTIONAL] Reranker model (BGE cross-encoder)
# Requires HF_TOKEN for gated models
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
HF_TOKEN=

# =============================================================================
# SECTION 10: Optional - Cloud LLM Providers (Optional Fallback)
# =============================================================================

# [OPTIONAL] Fireworks AI - cloud LLM fallback
FIREWORKS_AI_API_KEY=

# =============================================================================
# SECTION 11: Optional - Document Processing
# =============================================================================

# [OPTIONAL] Azure Document Intelligence
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=

# =============================================================================
# SECTION 12: Optional - RAG Enhancements
# =============================================================================

# [OPTIONAL] Cohere - chunk reranking
COHERE_API_KEY=

# [OPTIONAL] Tavily - web search
TAVILY_API_KEY=

# =============================================================================
# SECTION 13: Optional - Security
# =============================================================================

# [RECOMMENDED] Encryption key for API credentials in database
# Generate with: openssl rand -hex 32
DATA_SOURCE_ENCRYPTION_KEY=
