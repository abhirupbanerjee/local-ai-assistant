# =============================================================================
# Local AI Assistant - Azure VM Production Environment Template
# =============================================================================
# Copy to .env on the VM and replace placeholder values before starting Docker.

# Core
ADMIN_EMAILS=admin@yourdomain.com
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=https://laap.yourdomain.com
DOMAIN=laap.yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# Authentication
AUTH_DISABLED=false
ACCESS_MODE=allowlist
CREDENTIALS_ADMIN_PASSWORD=replace-with-secure-initial-password

# Database
DATABASE_PROVIDER=postgres
POSTGRES_USER=laap
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=laap
DATABASE_URL=postgresql://laap:replace-with-strong-postgres-password@postgres:5432/laap

# Local LLM, embeddings, and reranker
OLLAMA_MODE=docker
OLLAMA_API_BASE=http://ollama:11434
DEFAULT_OLLAMA_MODEL=qwen3:1.7b
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_PULL_MODELS=qwen3:1.7b,qwen3.5:0.8b,qwen3-embedding:0.6b,bbjson/bge-reranker-base
OLLAMA_RERANKER_MODEL=bbjson/bge-reranker-base
EMBEDDING_MODEL=ollama-qwen3-embedding:0.6b
EMBEDDING_DIMENSIONS=1024

# Infrastructure
QDRANT_HOST=qdrant
QDRANT_PORT=6333
REDIS_URL=redis://redis:6379
DATA_DIR=/app/data
MAX_UPLOAD_SIZE=500mb

# Optional security
DATA_SOURCE_ENCRYPTION_KEY=
HF_TOKEN=

# Optional integrations. Leave blank for all-local operation.
TAVILY_API_KEY=
COHERE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
