{
  "name": "local-ai-assistant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:embed": "npx tsx scripts/build-embed.ts",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test:connectivity": "npx tsx scripts/test-connectivity.ts",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:prod": "docker compose up -d --build",
    "docker:prod:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "db:setup": "npx tsx src/lib/db/setup.ts",
    "db:types": "kysely-codegen --out-file src/lib/db/db-types.ts",
    "cleanup:expired": "npx tsx src/scripts/cleanup-expired-outputs.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@azure/ai-form-recognizer": "^5.1.0",
    "@google/genai": "1.42.0",
    "@mistralai/mistralai": "1.10.0",
    "@qdrant/js-client-rest": "^1.16.2",
    "@sendgrid/mail": "^8.1.6",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.16",
    "ajv": "^8.17.1",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cohere-ai": "7.20.0",
    "csv-parse": "^6.1.0",
    "dexie": "^4.2.1",
    "docx": "^9.5.1",
    "dotenv": "^17.2.3",
    "exceljs": "4.4.0",
    "html2canvas": "^1.4.1",
    "kysely": "0.28.11",
    "lucide-react": "^0.468.0",
    "mammoth": "1.12.0",
    "mermaid": "11.12.2",
    "next": "^16.1.6",
    "next-auth": "^4.24.11",
    "officeparser": "6.0.7",
    "openai": "6.25.0",
    "pdf-parse": "1.1.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.0.1",
    "recharts": "^3.6.0",
    "redis": "^4.7.0",
    "remark-gfm": "^4.0.0",
    "sharp": "0.34.5",
    "uuid": "^11.0.3",
    "wav": "^1.0.2",
    "yaml": "^2.8.2",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/pdfkit": "^0.17.4",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/recharts": "^1.8.29",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.1.1",
    "kysely-codegen": "^0.20.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "lodash-es": "4.17.23"
  }
}
