# =============================================================================
# Local AI Assistant - Azure Container Apps Production Environment
# =============================================================================
#
# This file is for production deployment on Azure Container Apps.
# Uses Azure-managed services for database, cache, and vector store.
#
# =============================================================================

# =============================================================================
# SECTION 1: Core Configuration
# =============================================================================

# Your Azure AD admin emails
ADMIN_EMAILS=admin@yourdomain.com

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-secure-random-string-here

# Your Azure domain
NEXTAUTH_URL=https://your-app.azurecontainerapps.io

# =============================================================================
# SECTION 2: LLM Configuration (Ollama)
# =============================================================================

# Ollama endpoint - can be internal to VNET or separate container
# Option 1: Ollama in same container apps (internal)
# OLLAMA_API_BASE=http://localhost:11434
# Option 2: Ollama on separate VM/container (external)
OLLAMA_API_BASE=http://ollama-internal-ip:11434

# Default model
DEFAULT_OLLAMA_MODEL=gemma3:latest

# Ollama runtime settings
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PARALLEL=2
OLLAMA_CONTEXT_LENGTH=8192

# =============================================================================
# SECTION 3: Database Configuration (Azure Database for PostgreSQL)
# =============================================================================

DATABASE_PROVIDER=postgres
POSTGRES_USER=localaiassistant
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_DB=localaiassistant

# Azure Database for PostgreSQL connection string
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://localaiassistant:your-secure-postgres-password@your-postgres-server.postgres.database.azure.com:5432/localaiassistant

# Connection pool settings
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_POOL_CONNECTION_TIMEOUT=10000

# =============================================================================
# SECTION 4: Vector Store (Azure AI Search or Qdrant on ACI)
# =============================================================================

# Option 1: Azure AI Search
# VECTOR_STORE_PROVIDER=azure-search
# AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
# AZURE_SEARCH_API_KEY=your-search-api-key

# Option 2: Qdrant on Azure Container Instances
VECTOR_STORE_PROVIDER=qdrant
QDRANT_HOST=your-qdrant-internal-ip
QDRANT_PORT=6333
QDRANT_API_KEY=

# =============================================================================
# SECTION 5: Redis Cache (Azure Cache for Redis)
# =============================================================================

REDIS_URL=redis://your-redis-cache.redis.cache.windows.net:6380?ssl=true

# =============================================================================
# SECTION 6: Storage & Uploads
# =============================================================================

DATA_DIR=/app/data
MAX_UPLOAD_SIZE=500mb

# =============================================================================
# SECTION 7: Authentication (Azure AD)
# =============================================================================

# Disable auth = false for production
AUTH_DISABLED=false

# Azure AD OAuth (recommended for enterprise)
AZURE_AD_CLIENT_ID=your-azure-app-client-id
AZURE_AD_CLIENT_SECRET=your-azure-app-client-secret
AZURE_AD_TENANT_ID=your-azure-tenant-id

# Optional: Email/password as fallback
# EMAIL_AUTH_ENABLED=true
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user@yourdomain.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=noreply@yourdomain.com

ACCESS_MODE=allowlist

# =============================================================================
# SECTION 8: Production Deployment
# =============================================================================

DOMAIN=your-app.azurecontainerapps.io
ACME_EMAIL=admin@yourdomain.com

# Allowed embed origins (if using /e/* embed routes)
ALLOWED_EMBED_ORIGINS=https://portal.yourdomain.com

# =============================================================================
# SECTION 9: Embeddings & Reranking
# =============================================================================

# Local embeddings (transformers.js)
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_DIMENSIONS=1024

# Optional: Azure OpenAI embeddings
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIMENSIONS=3072
# AZURE_OPENAI_EMBEDDING_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_EMBEDDING_API_KEY=your-embedding-key

# Optional: Cloud reranker
# COHERE_API_KEY=your-cohere-key

# =============================================================================
# SECTION 10: Optional - Cloud LLM Fallback
# =============================================================================

# Azure OpenAI (recommended for fallback)
# OPENAI_API_KEY=your-azure-openai-key
# OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek (optional)
# DEEPSEEK_API_KEY=sk-...

# =============================================================================
# SECTION 11: Optional - Document Processing
# =============================================================================

# Azure Document Intelligence (for better PDF/DOCX extraction)
AZURE_DI_ENDPOINT=https://your-di-resource.cognitiveservices.azure.com
AZURE_DI_KEY=your-di-key

# =============================================================================
# SECTION 12: Optional - RAG Enhancements
# =============================================================================

# Tavily (web search)
# TAVILY_API_KEY=your-tavily-key

# Cohere (reranking)
# COHERE_API_KEY=your-cohere-key

# =============================================================================
# SECTION 13: Security
# =============================================================================

# Generate with: openssl rand -hex 32
DATA_SOURCE_ENCRYPTION_KEY=generate-secure-32-byte-hex-key-here

# =============================================================================
# SECTION 14: Azure-Specific Settings
# =============================================================================

# Container Apps specific
WEBSITE_NODE_DEFAULT_VERSION=~20
WEBSITE_VNET_ROUTE_ALL=1

# Logging
LOG_LEVEL=info
NEXT_TELEMETRY_DISABLED=1