# =============================================================================
# Local AI Assistant - Azure VM Production Configuration
# =============================================================================
#
# This is a production-ready template for Azure VM deployment.
# Generated secrets will be filled in by setup.sh
#
# Domain: laap.abhirup.app
#
# =============================================================================

# =============================================================================
# SECTION 1: Core Configuration
# =============================================================================

# Admin email addresses (comma-separated)
ADMIN_EMAILS=mailabhirupbanerjee@gmail.com

# NextAuth secret (generate with: openssl rand -base64 32)
# Will be auto-generated by setup.sh if left empty
NEXTAUTH_SECRET=

# Production URL
NEXTAUTH_URL=https://laap.abhirup.app

# =============================================================================
# SECTION 2: LLM Configuration (Ollama)
# =============================================================================

# Ollama mode: "docker" (runs in Docker container)
OLLAMA_MODE=docker

# Ollama API Base URL (Docker internal)
OLLAMA_API_BASE=http://ollama:11434

# Default Ollama model
DEFAULT_OLLAMA_MODEL=qwen3:1.7b

# Models to preload (chat models only - embeddings use local models)
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_PULL_MODELS=qwen3:1.7b,qwen3.5:0.8b

# Ollama runtime settings
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PARALLEL=2
OLLAMA_CONTEXT_LENGTH=8192

# =============================================================================
# SECTION 3: Database Configuration
# =============================================================================

# PostgreSQL configuration
DATABASE_PROVIDER=postgres
POSTGRES_USER=laap
POSTGRES_PASSWORD=
POSTGRES_DB=laap

# Connection pool settings
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_POOL_CONNECTION_TIMEOUT=10000

# =============================================================================
# SECTION 4: Vector Store (Qdrant)
# =============================================================================

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# =============================================================================
# SECTION 5: Redis Cache
# =============================================================================

REDIS_URL=redis://redis:6379

# =============================================================================
# SECTION 6: Storage & Uploads
# =============================================================================

DATA_DIR=/app/data
MAX_UPLOAD_SIZE=500mb

# =============================================================================
# SECTION 7: Authentication
# =============================================================================

# Disable auth bypass in production
AUTH_DISABLED=false

# Initial admin password - CHANGE THIS AFTER FIRST LOGIN
CREDENTIALS_ADMIN_PASSWORD=CHANGE_ME_ON_FIRST_LOGIN

# Azure AD OAuth (optional - configure after first login)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Google OAuth (optional - configure after first login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Access control mode
ACCESS_MODE=allowlist

# =============================================================================
# SECTION 8: Production Deployment
# =============================================================================

# Domain for Traefik routing
DOMAIN=laap.abhirup.app

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=mailabhirupbanerjee@gmail.com

# Allowed origins for iframe embedding (optional)
ALLOWED_EMBED_ORIGINS=

# =============================================================================
# SECTION 9: Embeddings & Reranking
# =============================================================================

# Local embedding model (in-process, no Ollama needed)
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024

# Reranker model (BGE cross-encoder)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# HuggingFace token for gated models
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# =============================================================================
# SECTION 10: Optional - Cloud LLM Providers
# =============================================================================

# Fireworks AI - cloud LLM fallback
FIREWORKS_AI_API_KEY=

# =============================================================================
# SECTION 11: Optional - Document Processing
# =============================================================================

# Azure Document Intelligence
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=

# =============================================================================
# SECTION 12: Optional - RAG Enhancements
# =============================================================================

# Cohere - chunk reranking
COHERE_API_KEY=

# Tavily - web search
TAVILY_API_KEY=

# =============================================================================
# SECTION 13: Security
# =============================================================================

# Encryption key for API credentials in database
# Will be auto-generated by setup.sh if left empty
DATA_SOURCE_ENCRYPTION_KEY=